# Copy this file to .env.local and fill in values for your environment
# .env.local is gitignored and should never be committed

# ---------------------------------------------------------------
# DEV ONLY: proxy target (change in nuxt.config.ts devApiTarget)
# ---------------------------------------------------------------
# https profile (Visual Studio):  https://127.0.0.1:7053
# http profile (Visual Studio):   http://127.0.0.1:5274
# Docker/Podman container:        http://127.0.0.1:8080

# ---------------------------------------------------------------
# PRODUCTION: public API base URL (set on Vercel / hosting platform)
# Leave empty in dev — the dev proxy handles it
# ---------------------------------------------------------------
# NUXT_PUBLIC_API_BASE=https://api.yourdomain.com
